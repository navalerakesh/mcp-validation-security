        <tr><td><code>list_repos</code></td><td>Passed</td><td>80.00</td></tr>
      </tbody>
    </table>
  </div>
</div>

            <div class="section">
  <h2>Resource Capabilities</h2>
  <p><strong>Resources Discovered:</strong> 1 &middot; <strong>Accessible:</strong> 1</p>
  <div class="detailed-section">
    <table class="data-table">
      <thead><tr><th align="left">Name</th><th align="left">URI</th><th align="left">MIME Type</th><th align="left">Size</th><th align="left">Status</th></tr></thead>
